{
  "name": "figma-rest-mcp-server",
  "version": "0.1.1",
  "type": "module",
  "description": "Local MCP server for reading Figma design data through the Figma REST API.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "bin": {
    "figma-rest-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx src/cli.ts serve",
    "cli": "tsx src/cli.ts",
    "figma:pat": "tsx src/cli.ts auth",
    "pack:dry-run": "pnpm pack --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  }
}
